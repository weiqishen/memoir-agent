{
  "name": "memoir-agent",
  "version": "0.1.0",
  "description": "AI-powered personal memoir archival system — Claude Code skill + pywebview desktop viewer",
  "keywords": ["memoir", "claude-code", "biographer", "ai", "pywebview", "agent"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weiqishen/memoir-agent.git"
  },
  "license": "MIT",
  "bin": {
    "memoir": "./cli.js"
  },
  "files": [
    "cli.js",
    "lib/build-asset-sync.js",
    "lib/npm-runner.js",
    "lib/update-source.js",
    "scripts/install-python-deps.js",
    "requirements.txt",
    "template/",
    "template/memoirs/webapp/dist/memoirs.manifest.json",
    "template/memoirs/webapp/public/memoirs.manifest.json",
    "README.md"
  ],
  "scripts": {
    "test": "node --test tests/*.cjs && python -m unittest discover -s tests -p \"test_*.py\"",
    "postinstall": "node -e \"const fs=require('fs');const p='scripts/install-python-deps.js';if(!fs.existsSync(p)){process.exit(0);}require('child_process').spawnSync(process.execPath,[p],{stdio:'inherit'});\""
  },
  "engines": {
    "node": ">=16"
  }
}
